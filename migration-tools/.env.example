# Conexión a la base de datos de TallerHub
DATABASE_URL="postgresql://user:password@localhost:5432/tallerhub?schema=public"

# ID del tenant destino (obligatorio)
TENANT_ID="uuid-del-tenant"

# ID de la sucursal destino (obligatorio)
BRANCH_ID="uuid-de-la-sucursal"

# ID del usuario que ejecuta la migración (para auditoría)
MIGRATION_USER_ID="uuid-del-usuario-admin"

# Directorio donde están los CSV exportados de Gestioo
CSV_DIR="./samples"

# Modo de ejecución
DRY_RUN=false
LOG_LEVEL=info
